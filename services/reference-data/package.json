    "@aip/postgres-client": "workspace:*",
    "@aip/shared-contracts": "workspace:*",
    "drizzle-orm": "^0.36.1",
    "fastify": "^5.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
