{
  "name": "@aip/api-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Public REST entry point. Fastify shell with request-id propagation, canonical error envelope, auth decode stub, rate-limit hook, and /metrics. Real auth + RBAC enforcement lands in T-504; real rate limiting in T-505.",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts"
  },
  "dependencies": {
    "@aip/auth-jwt": "workspace:*",
    "@aip/http-safety": "workspace:*",
    "@aip/logger": "workspace:*",
    "@aip/metrics": "workspace:*",
    "@aip/redis-client": "workspace:*",
    "@aip/security-events": "workspace:*",
    "@aip/shared-contracts": "workspace:*",
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
