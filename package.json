{
  "name": "airport-inspection-platform",
  "version": "0.5.0",
  "private": true,
  "description": "Airport Inspection Platform — production-style portfolio demo of an AI-assisted airport inspection system (sensor ingestion, AI inference, 10-layer validation, ops dashboard).",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "db:migrate": "pnpm --filter @aip/db-schema db:migrate",
    "db:seed": "pnpm --filter @aip/db-schema db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,mjs,cjs,json,md,yaml,yml}\"",
    "e2e": "playwright test --config=__TEST__/e2e/playwright.config.ts",
    "e2e:integration": "playwright test --config=__TEST__/e2e/playwright.integration.config.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "eslint": "^9.12.0",
    "ioredis": "^5.4.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1"
  }
}
