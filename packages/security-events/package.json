{
  "name": "@aip/security-events",
  "version": "0.6.0",
  "private": true,
  "description": "Security audit event types + publisher. Emits `events.security.*` for login/logout/refresh/access.denied/rate.limit.blocked, audit-service writes them to the hash-chained audit log.",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@aip/logger": "workspace:*",
    "@aip/redis-client": "workspace:*",
    "@aip/shared-contracts": "workspace:*",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
