{
  "name": "@aip/shared-contracts",
  "version": "0.6.0",
  "private": true,
  "description": "Shared cross-service contracts — TypeScript types and Zod schemas for domain entities, enums, event envelopes, API DTOs, WS messages, and error codes.",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./enums": {
      "types": "./src/enums/index.ts",
      "default": "./src/enums/index.ts"
    },
    "./domain": {
      "types": "./src/domain/index.ts",
      "default": "./src/domain/index.ts"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./src/events/index.ts"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./ws": {
      "types": "./src/ws/index.ts",
      "default": "./src/ws/index.ts"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "default": "./src/errors/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
