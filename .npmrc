auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
save-exact=false

# Hoist frontend test-time packages so vitest can resolve them from the
# centralized __TEST__/ directory (which sits above any workspace).
public-hoist-pattern[]=@vue/test-utils
public-hoist-pattern[]=@vitejs/plugin-vue
public-hoist-pattern[]=happy-dom
